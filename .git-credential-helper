#!/bin/bash
# Git 认证助手 - 使用 .git-credentials 文件

CRED_FILE="/opt/data/workspace/ai-daily-briefing/.git-credentials"

case "$1" in
    get)
        # 读取凭证并输出 Git credential 格式
        if [ -f "$CRED_FILE" ]; then
            # 解析 URL 格式: https://user:pass@host
            cred=$(cat "$CRED_FILE" | tr -d '\n\r')
            # 提取用户名和密码
            username=$(echo "$cred" | sed -n 's|https://\([^:]*\):.*@.*|\1|p')
            password=$(echo "$cred" | sed -n 's|https://[^:]*:\([^@]*\)@.*|\1|p')
            
            echo "protocol=https"
            echo "host=github.com"
            echo "username=$username"
            echo "password=$password"
        fi
        ;;
    store)
        # 不支持写入
        :
        ;;
    erase)
        # 不支持删除
        :
        ;;
esac
