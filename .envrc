#!/bin/bash
# Environment configuration for AI Daily Briefing
export GIT_DIR=/opt/data/workspace/ai-daily-briefing/.git
export GIT_WORK_TREE=/opt/data/workspace/ai-daily-briefing
export PATH=/opt/data/workspace/ai-daily-briefing/.bin:$PATH
export GIT_CONFIG_COUNT=1
export GIT_CONFIG_KEY_0=credential.helper
export GIT_CONFIG_VALUE_0=/opt/data/workspace/ai-daily-briefing/.git-credential-helper
